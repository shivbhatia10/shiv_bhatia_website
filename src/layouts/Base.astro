---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Shiv Bhatia", description = "Programmer in London." } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpg" href="/favicon.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="mx-auto max-w-page px-6 md:px-8 py-10 md:py-16">
      <header
        class="flex items-baseline justify-between gap-4 pb-8 border-b border-rule"
      >
        <a
          href="/"
          class="font-serif text-lg md:text-xl no-underline hover:text-ink"
        >
          Shiv Bhatia
        </a>
        <Nav />
      </header>

      <main class="py-10 md:py-14">
        <slot />
      </main>

      <footer
        class="mt-10 pt-6 border-t border-rule font-sans text-xs text-muted flex flex-wrap gap-x-4 gap-y-1 justify-between"
      >
        <span>&copy; {new Date().getFullYear()} Shiv Bhatia</span>
        <span class="flex gap-4">
          <a
            class="no-underline hover:text-ink"
            href="https://github.com/shivbhatia10"
            target="_blank"
            rel="noopener noreferrer">github</a
          >
          <a
            class="no-underline hover:text-ink"
            href="https://www.linkedin.com/in/shiv-bhatia/"
            target="_blank"
            rel="noopener noreferrer">linkedin</a
          >
        </span>
      </footer>
    </div>
  </body>
</html>
