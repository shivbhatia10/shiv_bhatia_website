---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<Base title="Blog · Shiv Bhatia" description="Essays and notes.">
  <section class="max-w-prose">
    <h1 class="font-serif text-3xl md:text-4xl tracking-tight">Blog</h1>
    <p class="text-muted mt-3">Essays, notes, and half-baked thoughts.</p>
  </section>

  <section class="mt-10 md:mt-14">
    {
      posts.length === 0 ? (
        <p class="text-muted italic">Nothing here yet.</p>
      ) : (
        <ul class="divide-y divide-rule border-y border-rule">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="group grid md:grid-cols-[8rem_1fr] gap-1 md:gap-8 py-5 no-underline"
              >
                <time
                  datetime={post.data.date.toISOString()}
                  class="font-sans text-xs uppercase tracking-wider text-muted md:pt-1.5"
                >
                  {fmt(post.data.date)}
                </time>
                <div>
                  <h2 class="font-serif text-xl group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h2>
                  {post.data.description && (
                    <p class="text-muted mt-1 text-[15px]">
                      {post.data.description}
                    </p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
