---
import Base from "../../layouts/Base.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Base title={`${post.data.title} · Shiv Bhatia`} description={post.data.description}>
  <article class="max-w-prose">
    <header class="mb-8">
      <p class="font-sans text-xs uppercase tracking-wider text-muted">
        <a href="/blog" class="no-underline hover:text-ink">&larr; blog</a>
        <span class="mx-2">/</span>
        <time datetime={post.data.date.toISOString()}>
          {fmt(post.data.date)}
        </time>
      </p>
      <h1 class="font-serif text-3xl md:text-4xl tracking-tight leading-tight mt-3">
        {post.data.title}
      </h1>
      {
        post.data.description && (
          <p class="text-muted mt-3 text-lg">{post.data.description}</p>
        )
      }
    </header>

    <div
      class="prose prose-neutral max-w-none font-serif
             prose-headings:font-serif prose-headings:tracking-tight
             prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-3
             prose-h3:text-xl
             prose-p:leading-[1.7]
             prose-a:text-accent prose-a:no-underline hover:prose-a:underline
             prose-code:font-mono prose-code:text-[0.9em] prose-code:bg-ink/[0.04] prose-code:px-1 prose-code:py-0.5 prose-code:rounded
             prose-code:before:content-none prose-code:after:content-none
             prose-pre:bg-ink prose-pre:text-paper prose-pre:rounded-md
             prose-blockquote:border-l-2 prose-blockquote:border-rule prose-blockquote:text-muted prose-blockquote:not-italic"
    >
      <Content />
    </div>
  </article>
</Base>
